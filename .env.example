# Chave da API Anthropic — https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Base URL do WAHA (padrão local)
WAHA_BASE_URL=http://localhost:8080

# Nome da sessão WAHA (padrão: default)
WAHA_SESSION=default

# API key do WAHA
WAHA_API_KEY=

# Senha do dashboard WAHA
WAHA_DASHBOARD_PASSWORD=

# Porta do backend Python
PORT=3000

# Whitelist de números que o bot responde (separados por vírgula, formato: 5544999999999)
# Deixe em branco para responder a todos
TEST_PHONES=

# ─── Loja (dealership) ──────────────────────────────────────────────────────
# Nesta fase o sistema atende uma única loja. Estes dados viram a linha inicial
# da tabela `dealerships` na primeira sincronização/execução.
DEALERSHIP_NAME=Company Imports
DEALERSHIP_CITY=Maringá/PR
# PREENCHER com dado real antes de ir pra produção — não inventar no prompt.
DEALERSHIP_PHONE=
DEALERSHIP_ADDRESS=
DEALERSHIP_HOURS=
# Telefone do vendedor/gerente que recebe os alertas de lead (formato: 5544999999999)
DEALERSHIP_STAFF_PHONE=

# ─── Conector de estoque — Supabase da loja de origem ───────────────────────
# Usado por sync_inventory.py para importar veículos + fotos pro banco local.
# A chave é a "anon key" pública do Supabase do site da loja (não é secreta, mas
# mesmo assim não fica hardcoded no repo — preencher no seu .env local).
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=sua-anon-key-aqui

# ─── Painel administrativo ───────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=troque-esta-senha
# Chave usada para assinar o cookie de sessão — gere uma aleatória em produção
SESSION_SECRET_KEY=troque-esta-chave-secreta
