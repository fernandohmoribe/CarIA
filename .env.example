# Chave da API Anthropic — https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Base URL do WAHA (padrão local)
WAHA_BASE_URL=http://localhost:8080

# Nome da sessão WAHA (padrão: default)
WAHA_SESSION=default

# API key do WAHA
WAHA_API_KEY=

# Senha do dashboard WAHA
WAHA_DASHBOARD_PASSWORD=

# Porta do backend Python
PORT=3000

# Interface em que o backend escuta (opcional). Padrão 0.0.0.0 (todas, bom pra dev local).
# Em produção atrás de um proxy reverso (Caddy/nginx), pode restringir pro IP interno que o
# proxy usa pra falar com o app (ex: o gateway da rede Docker do proxy), deixando a porta
# inacessível direto da internet — só o proxy alcança.
HOST=0.0.0.0

# Fuso horário do negócio, em horas de offset de UTC — independe do fuso do servidor
# (ex: Hetzner na Europa). Padrão -3 (Brasília). Brasil não observa horário de verão desde 2019,
# então um offset fixo é suficiente sem precisar de tzdata/pytz.
TIMEZONE_OFFSET_HOURS=-3

# Whitelist de números que o bot responde (separados por vírgula, formato: 5544999999999)
# Deixe em branco para responder a todos
TEST_PHONES=

# Atraso mínimo, em segundos, entre a mensagem do cliente e a resposta do bot — responder
# sempre instantaneamente é um padrão que a WhatsApp Web não-oficial associa a bot. Padrão: 5.
SEGUNDOS_MINIMOS_RESPOSTA=5

# ─── Loja (dealership) ──────────────────────────────────────────────────────
# Nesta fase o sistema atende uma única loja. Estes dados viram a linha inicial
# da tabela `dealerships` na primeira sincronização/execução.
DEALERSHIP_NAME=Minha Loja
DEALERSHIP_CITY=Maringá/PR
# PREENCHER com dado real antes de ir pra produção — não inventar no prompt.
DEALERSHIP_PHONE=
DEALERSHIP_ADDRESS=
DEALERSHIP_HOURS=
# Telefone do vendedor/gerente que recebe os alertas de lead (formato: 5544999999999)
DEALERSHIP_STAFF_PHONE=

# ─── Conector de estoque — escolha o tipo ───────────────────────────────────
# supabase   → loja cujo site usa Supabase como backend (lê via API REST/PostgREST)
# autocerto  → loja cujo site roda na plataforma AutoCerto (scraping de HTML, sem API)
DEALERSHIP_CONNECTOR_TYPE=supabase

# ─── Conector Supabase (usado só quando DEALERSHIP_CONNECTOR_TYPE=supabase) ──
# A chave é a "anon key" pública do Supabase do site da loja (não é secreta, mas
# mesmo assim não fica hardcoded no repo — preencher no seu .env local).
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=sua-anon-key-aqui

# ─── Conector AutoCerto (usado só quando DEALERSHIP_CONNECTOR_TYPE=autocerto) ─
AUTOCERTO_SITE_URL=https://www.exemplo-da-loja.com.br

# ─── Painel administrativo ───────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=troque-esta-senha
# Chave usada para assinar o cookie de sessão — gere uma aleatória em produção
SESSION_SECRET_KEY=troque-esta-chave-secreta

# ─── Instagram (opcional, Fase 2 — vídeos de depoimento na home) ────────────
# Sem isso configurado, sync_instagram.py não faz nada e a seção de vídeos
# simplesmente não aparece no site. Pra ativar:
#   1. Conta do Instagram tipo Profissional (Business ou Creator).
#   2. App no Meta for Developers (developers.facebook.com) com o produto
#      "Instagram API" configurado (fluxo "Instagram API with Instagram Login").
#   3. Gerar um access token de longa duração (~60 dias, precisa renovar
#      periodicamente) com permissão instagram_basic.
#   4. Pegar o Instagram Business Account ID no mesmo processo.
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# ─── Google Places (opcional, Fase 3 — avaliações do Google na home) ────────
# Sem isso configurado, sync_google_reviews.py não faz nada e a seção de
# avaliações simplesmente não aparece no site. Pra ativar:
#   1. Projeto no Google Cloud Console com faturamento ativado.
#   2. Ativar a Places API e gerar uma API key restrita a ela.
#   3. Achar o Place ID do negócio (Google "Place ID Finder").
# Limitação da própria API do Google: retorna no máximo 5 avaliações (as mais
# relevantes, escolhidas pelo Google — não dá pra puxar todas via API).
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=

# ─── Analytics do site público (opcional) ───────────────────────────────────
# Cada um é independente do outro — sem preencher, o script correspondente
# simplesmente não é renderizado em nenhuma página (nenhum request extra sai
# do navegador do visitante até você configurar).
#   GA_MEASUREMENT_ID: Measurement ID do Google Analytics 4 (formato G-XXXXXXX).
#   META_PIXEL_ID: ID do Meta Pixel (Gerenciador de Eventos, Facebook Business).
GA_MEASUREMENT_ID=
META_PIXEL_ID=
